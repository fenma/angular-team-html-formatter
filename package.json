{
  "name": "angular-team-html-formatter",
  "displayName": "Angular Team HTML Formatter",
  "description": "Line-preserving HTML formatter for Angular templates with project-based tag rules.",
  "version": "0.2.1",
  "publisher": "Fenma",
  "repository": {
    "type": "git",
    "url": "https://github.com/fenma/angular-team-html-formatter.git"
  },
  "homepage": "https://github.com/fenma/angular-team-html-formatter",
  "bugs": {
    "url": "https://github.com/fenma/angular-team-html-formatter/issues"
  },
  "license": "MIT",
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#0F172A",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "Formatters",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:html",
    "onStartupFinished"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "angularTeamHtmlFormatter.formatDocument",
        "title": "Format HTML with Team Formatter"
      },
      {
        "command": "angularTeamHtmlFormatter.validateConfig",
        "title": "Validate HTML Formatter Config"
      },
      {
        "command": "angularTeamHtmlFormatter.showActiveConfig",
        "title": "Show Active HTML Formatter Config"
      }
    ],
    "configuration": {
      "title": "Angular Team HTML Formatter",
      "properties": {
        "angularTeamHtmlFormatter.enableDebugLogs": {
          "type": "boolean",
          "default": false,
          "description": "Enable formatter debug output in the extension output channel."
        }
      }
    }
  },
  "scripts": {
    "test": "node --test",
    "test:watch": "node --test --watch",
    "generate:icon": "node ./scripts/generate-icon-png.js",
    "package:vsix": "node ./scripts/package-vsix.js",
    "publish:vsix": "node ./scripts/package-vsix.js"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.0.0"
  },
  "keywords": [
    "angular",
    "html",
    "formatter",
    "primeng",
    "vscode-extension"
  ]
}
